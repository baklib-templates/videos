<!DOCTYPE html>
<html class="scroll-pt-16 scroll-smooth bg-base-100 font-sans antialiased" lang="{{ site.language }}" data-theme="dark">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="author" content="Baklib">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% meta_tags %}
    {{ 'stylesheets/application.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
    {{ 'javascripts/application.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
    {{ site.settings.head_html }}

    <style>
      :root {
        /* daisyui css variables */
        --color-base-100: hsl(var(--theme-color-base-100));
        --color-base-200: hsl(var(--theme-color-base-200));
        --color-base-300: hsl(var(--theme-color-base-300));
        --color-base-content: hsl(var(--theme-color-base-content));
        --color-primary: hsl(var(--theme-color-primary));
        --color-primary-content: hsl(var(--theme-color-primary-content));
        --color-secondary: hsl(var(--theme-color-secondary));
        --color-secondary-content: hsl(var(--theme-color-secondary-content));
        --color-accent: hsl(var(--theme-color-accent));
        --color-accent-content: hsl(var(--theme-color-accent-content));
        --color-neutral: hsl(var(--theme-color-neutral));
        --color-neutral-content: hsl(var(--theme-color-neutral-content));
        --color-info: hsl(var(--theme-color-info));
        --color-info-content: hsl(var(--theme-color-info-content));
        --color-success: hsl(var(--theme-color-success));
        --color-success-content: hsl(var(--theme-color-success-content));
        --color-warning: hsl(var(--theme-color-warning));
        --color-warning-content: hsl(var(--theme-color-warning-content));
        --color-error: hsl(var(--theme-color-error));
        --color-error-content: hsl(var(--theme-color-error-content));
      }

      :root:has(input.theme-controller[value=dark]:checked),
      [data-theme="dark"] {
        --color-base-100: hsl(var(--theme-color-base-100-dark));
        --color-base-200: hsl(var(--theme-color-base-200-dark));
        --color-base-300: hsl(var(--theme-color-base-300-dark));
        --color-base-content: hsl(var(--theme-color-base-content-dark));
        --color-primary: hsl(var(--theme-color-primary-dark));
        --color-primary-content: hsl(var(--theme-color-primary-content-dark));
        --color-secondary: hsl(var(--theme-color-secondary-dark));
        --color-secondary-content: hsl(var(--theme-color-secondary-content-dark));
        --color-accent: hsl(var(--theme-color-accent-dark));
        --color-accent-content: hsl(var(--theme-color-accent-content-dark));
        --color-neutral: hsl(var(--theme-color-neutral-dark));
        --color-neutral-content: hsl(var(--theme-color-neutral-content-dark));
        --color-info: hsl(var(--theme-color-info-dark));
        --color-info-content: hsl(var(--theme-color-info-content-dark));
        --color-success: hsl(var(--theme-color-success-dark));
        --color-success-content: hsl(var(--theme-color-success-content-dark));
        --color-warning: hsl(var(--theme-color-warning-dark));
        --color-warning-content: hsl(var(--theme-color-warning-content-dark));
        --color-error: hsl(var(--theme-color-error-dark));
        --color-error-content: hsl(var(--theme-color-error-content-dark));
      }
    </style>
  </head>

  <body class="min-h-screen text-base-content" x-data>
    <div class="isolate">
      {% render 'shell_open', current_page: page %}
      <turbo-frame id="main-content-frame" data-turbo-action="advance" class="flex min-h-screen flex-col">
        {{ content_for_layout }}
      </turbo-frame>
      {% render 'footer' %}
      {% render 'shell_close' %}
    </div>
  </body>
</html>
