[
  {
    "name": "theme_info",
    "theme_name": "jobs",
    "theme_label": "jobs",
    "theme_description": "专业级企业雇主品牌与招聘门户。复刻硅谷顶级 Job Board 视觉范式，内置结构化招聘 Schema，支持一键发布职位、在线投递与简历收集，助力企业打造高转化率的人才引力场。",
    "theme_version": "0.0.1",
    "theme_syntax_version": "v2",
    "theme_scope": "cms",
    "theme_author": "Baklib",
    "theme_documentation_url": "https://help.baklib.cn/theme/jobs",
    "theme_support_url": "https://help.baklib.cn/theme/jobs",
    "theme_thumb_url": "images/theme/thumb.png",
    "theme_preview_images": [
      "images/theme/preview-index.png",
      "images/theme/preview-page.png"
    ],
    "theme_languages": [
      { "name": "中文简体", "value": "zh-CN" },
      { "name": "English", "value": "en" }
    ],
    "recommendations": {
      "color_schemas": {
        "default": {
          "name": "Teal / Orange",
          "colors": {
            "--theme-color-primary": "#0d9488",
            "--theme-color-secondary": "#ea580c",
            "--theme-color-accent": "#64748b",
            "--theme-color-info": "#0ea5e9",
            "--theme-color-success": "#22c55e",
            "--theme-color-warning": "#f59e0b"
          }
        }
      }
    }
  },
  {
    "name": "站点设置",
    "settings": [
      {
        "id": "head_html",
        "type": "html",
        "label": "Head 自定义代码",
        "rows": 8
      },
      {
        "id": "brand_name",
        "type": "text",
        "label": "品牌名称",
        "default": "JobBoard"
      },
      {
        "id": "brand_slogan",
        "type": "text",
        "label": "品牌标语",
        "default": "Join the best teams in the industry."
      },
      {
        "id": "cta_label",
        "type": "text",
        "label": "右上角 CTA 文案",
        "default": "Apply now"
      },
      {
        "id": "press_logos",
        "type": "code",
        "language": "html",
        "label": "Press logos（HTML）",
        "info": "粘贴 Cruip JobBoard 的 press logos 区块 HTML（svg/img），将按原样渲染。",
        "default": ""
      },
      {
        "id": "hero_html",
        "type": "html",
        "label": "Hero 自定义 HTML",
        "rows": 10,
        "info": "可选：填写后将完全替换默认 Hero 区块（注意保留容器宽度/间距类名）。",
        "default": "preset:hero.html"
      },
      {
        "id": "hero_bg_url",
        "type": "image_picker",
        "ratio": "16:9",
        "width": 300,
        "label": "Hero 背景图（全局）",
        "info": "可选：用于全站背景（body background-image）。建议上传与 hero 适配的宽幅图。",
        "default": ""
      },
      {
        "type": "header",
        "content": "职位字段下拉候选项（供 Job Post 引用）"
      },
      {
        "id": "company_name_options",
        "type": "textarea",
        "label": "Company options（每行一个值）",
        "info": "用于 Job Post 的「公司」下拉候选项。每行一个选项值。",
        "rows": 6,
        "default": "Acme Inc.\nMedium Inc.\nBeta Labs"
      },
      {
        "id": "location_options",
        "type": "textarea",
        "label": "Location options（每行一个值）",
        "info": "用于 Job Post 的「地点」下拉候选项。每行一个选项值。",
        "rows": 6,
        "default": "Remote\nShanghai\nLondon\nShenzhen"
      },
      {
        "id": "salary_options",
        "type": "textarea",
        "label": "Salary options（每行一个值）",
        "info": "用于 Job Post 的「薪资」下拉候选项。每行一个选项值。",
        "rows": 6,
        "default": "Negotiable\n$60K - $90K\n$75K - $100K\n$100K - $170K"
      },
      {
        "id": "employment_type_options",
        "type": "textarea",
        "label": "Employment type options（每行一个值）",
        "info": "用于 Job Post 的「类型」下拉候选项。每行一个选项值。",
        "rows": 6,
        "default": "Full-time\nPart-time\nInternship\nContract"
      }
    ]
  }
]

