{%- assign parent = page.parent -%}
{%- assign interviews_path = '' -%}
{%- assign interviews_title = 'theme.page.interviews' | t: 'Interviews' -%}
{%- assign root = site.pages['/'] -%}
{%- if root -%}
  {%- for p in root.children_in_list -%}
    {%- if p.template_name == 'channel.grid' -%}
      {%- assign interviews_path = p.path -%}
      {%- assign interviews_title = p.link_text | default: p.name -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign sibs = parent.children_in_list -%}
{%- assign next_lesson_path = '' -%}
{%- assign next_lesson_title = '' -%}
{%- assign next_lesson_desc = '' -%}
{%- assign seen = false -%}
{%- for x in sibs -%}
  {%- if seen -%}
    {%- assign next_lesson_path = x.path -%}
    {%- assign next_lesson_title = x.link_text | default: x.name -%}
    {%- assign next_lesson_desc = x.settings.description -%}
    {%- break -%}
  {%- endif -%}
  {%- if x.id == page.id -%}
    {%- assign seen = true -%}
  {%- endif -%}
{%- endfor -%}

{%- assign video_asset_url = page.settings.video_asset_url | presence -%}
{%- assign external_video_url = page.settings.external_video_url | presence -%}
{%- assign external_embed_url = external_video_url -%}
{%- assign is_external_embed = false -%}
{%- if video_asset_url == blank and external_video_url != blank -%}
  {%- if external_video_url contains 'youtube.com/watch' and external_video_url contains 'v=' -%}
    {%- assign youtube_id = external_video_url | split: 'v=' | last | split: '&' | first -%}
    {%- assign external_embed_url = 'https://www.youtube.com/embed/' | append: youtube_id -%}
    {%- assign is_external_embed = true -%}
  {%- elsif external_video_url contains 'youtu.be/' -%}
    {%- assign youtube_id = external_video_url | split: 'youtu.be/' | last | split: '?' | first -%}
    {%- assign external_embed_url = 'https://www.youtube.com/embed/' | append: youtube_id -%}
    {%- assign is_external_embed = true -%}
  {%- elsif external_video_url contains 'vimeo.com/' -%}
    {%- if external_video_url contains 'player.vimeo.com/video/' -%}
      {%- assign external_embed_url = external_video_url -%}
    {%- else -%}
      {%- assign vimeo_id = external_video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
      {%- assign external_embed_url = 'https://player.vimeo.com/video/' | append: vimeo_id -%}
    {%- endif -%}
    {%- assign is_external_embed = true -%}
  {%- endif -%}
{%- endif -%}
{%- assign poster = page.settings.thumb_image_url | presence -%}

{%- capture nav_breadcrumbs -%}
<nav class="flex flex-wrap items-center gap-2 text-sm text-base-content/70" aria-label="{{ 'theme.a11y.breadcrumb' | t: 'Breadcrumb' }}">
  <a href="{{ site.index_path }}" class="hover:text-primary">{{ 'theme.nav.home' | t: 'Home' }}</a>
  <span class="text-base-content/30">/</span>
  {%- if parent -%}
    <a href="{{ parent.path }}" class="max-md:hidden hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ parent.link_text | default: parent.name }}</a>
    <span class="text-base-content/30 max-md:hidden">/</span>
  {%- endif -%}
  <span class="font-medium text-base-content">{{ page.link_text | default: page.name }}</span>
</nav>
{%- endcapture -%}

{% render 'navbar', breadcrumbs: nav_breadcrumbs %}

<main class="grow px-4 sm:px-6">
  <div class="mx-auto max-w-7xl">
    {%- if video_asset_url != blank or external_video_url != blank -%}
      {%- if is_external_embed -%}
        <div class="-mx-2 sm:-mx-4">
          <div class="group aspect-video w-full rounded-2xl bg-base-200">
            <iframe
              class="aspect-video w-full rounded-2xl"
              src="{{ external_embed_url }}"
              title="{{ page.link_text | default: page.name }}"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      {%- else -%}
        <div class="-mx-2 sm:-mx-4" data-controller="video-player">
          <div
            data-video-player-target="container"
            class="group aspect-video w-full rounded-2xl bg-base-200"
          >
            <video
              id="lesson-video"
              data-video-player-target="video"
              class="aspect-video w-full rounded-2xl sm:group-data-offscreen:data-playing:fixed sm:group-data-offscreen:data-playing:bottom-4 sm:group-data-offscreen:data-playing:right-4 sm:group-data-offscreen:data-playing:z-10 sm:group-data-offscreen:data-playing:max-w-md sm:group-data-offscreen:data-playing:rounded-xl sm:group-data-offscreen:data-playing:shadow-lg"
              src="{{ video_asset_url | default: external_video_url }}"
              poster="{{ poster }}"
              preload="metadata"
              controls
              playsinline
            ></video>
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}

    <div class="mx-auto flex max-w-2xl gap-x-10 py-10 sm:py-14 lg:max-w-5xl">
      <div class="w-full flex-1">
        {%- if page.settings.title != blank -%}
          <p class="text-sm/7 font-semibold text-base-content/60">{{ page.settings.title }}</p>
        {%- endif -%}
        <h1 class="mt-2 text-3xl tracking-tight text-base-content">{{ page.link_text | default: page.name }}</h1>
        {%- if page.settings.description != blank -%}
          <p class="mt-4 text-base/7 text-base-content/70">{{ page.settings.description }}</p>
        {%- endif -%}

        <div id="content" class="prose mt-10 max-w-none">
          {{ page.settings.content }}
        </div>
        {%- if current_user and page.settings.protected_content != blank -%}
          <div class="mt-12 border-t border-base-300/20 pt-8">
            <h2 class="text-2xl font-medium tracking-tight text-base-content">{{ 'theme.page.protected_content' | t: 'Protected content' }}</h2>
            <div class="prose ProseMirror mt-6 max-w-none">
              {{ page.settings.protected_content }}
            </div>
          </div>
        {%- endif -%}

        <div class="mt-16 border-t border-base-300/20 pt-8">
          {%- if next_lesson_path != blank -%}
            {% render 'next_page_link',
              href: next_lesson_path,
              title: next_lesson_title,
              description: next_lesson_desc,
              label: ('theme.page.up_next' | t: 'Up next')
            %}
          {%- elsif parent and parent.template_name == 'channel' and interviews_path != blank -%}
            {% render 'next_page_link',
              href: interviews_path,
              title: interviews_title,
              description: ('theme.page.interviews_description' | t: 'Explore interviews with industry experts and thought leaders.'),
              label: ('theme.page.up_next' | t: 'Up next')
            %}
          {%- endif -%}
        </div>
      </div>

      <aside class="hidden w-64 shrink-0 lg:block" data-controller="toc" data-toc-root-id-value="content">
        <nav class="sticky top-16">
          <h2 class="text-sm/6 font-semibold text-base-content">{{ 'theme.page.on_this_page' | t: 'On this page' }}</h2>
          <ul class="mt-3 flex flex-col gap-3 border-l border-base-300/30 text-sm/6 text-base-content/70" data-toc-list></ul>
        </nav>
      </aside>
    </div>
  </div>
</main>

{% schema %}
  {
    "name": "t:schema.templates.page.name",
    "description": "t:schema.templates.page.description",
    "thumb_url": "images/theme/${lang}/page_poster.png",
    "preview_image_urls": ["images/theme/${lang}/page_poster.png"],
    "sub_page_templates": [],
    "settings": [
      { "id": "title", "type": "text", "label": "t:schema.templates.page.settings.title.label" },
      { "id": "description", "type": "textarea", "label": "t:schema.templates.page.settings.description.label", "to_markdown": true },
      {
        "id": "video_asset_url",
        "type": "video_picker",
        "label": "t:schema.templates.page.settings.video_asset_url.label",
        "ratio": "16:9",
        "width": 360,
        "info": "t:schema.templates.page.settings.video_asset_url.info"
      },
      { "id": "external_video_url", "type": "text", "label": "t:schema.templates.page.settings.external_video_url.label" },
      {
        "id": "thumb_image_url",
        "type": "image_picker",
        "ratio": "16:9",
        "width": 360,
        "label": "t:schema.templates.page.settings.thumb_image_url.label",
        "info": "t:schema.templates.page.settings.thumb_image_url.info"
      },
      { "id": "content", "type": "richtext", "label": "t:schema.templates.page.settings.content.label", "to_markdown": true },
      { "id": "protected_content", "type": "richtext", "label": "t:schema.templates.page.settings.protected_content.label", "to_markdown": true }
    ]
  }
{% endschema %}
