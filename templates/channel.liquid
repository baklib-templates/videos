{%- assign jobs = page.children_in_list | order_by: '-published_at' -%}

<main class="mx-auto max-w-6xl px-4 sm:px-6 py-10 md:py-12">
  <div class="mb-6">
    <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight text-slate-900">{{ page.link_text }}</h1>
    {%- if page.settings.description -%}
      <p class="mt-2 text-slate-600">{{ page.settings.description }}</p>
    {%- endif -%}
  </div>

  <div class="bg-white rounded-xl border border-slate-200 divide-y divide-slate-100">
    {%- for job in jobs -%}
      {% render 'job_card', job: job %}
    {%- else -%}
      <div class="p-6 text-sm text-slate-500">No jobs yet.</div>
    {%- endfor -%}
  </div>
</main>

{% schema %}
  {
    "name": "Jobs Channel",
    "description": "Job list page",
    "thumb_url": "images/theme/preview-index.png",
    "preview_image_urls": ["images/theme/preview-index.png"],
    "sub_page_templates": ["page"],
    "settings": [
      { "id": "title", "type": "text", "label": "Title" },
      { "id": "description", "type": "textarea", "label": "Description" }
    ]
  }
{% endschema %}

