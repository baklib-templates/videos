<div class="flow-root">
  <a
    href="{{ href }}"
    class="-mx-3 -my-2 flex gap-3 rounded-xl px-3 py-2 text-sm/7 hover:bg-base-content/5"
    data-turbo-frame="main-content-frame"
    data-turbo-action="advance"
  >
    <div class="flex h-[1.75rem] shrink-0 items-center">
      {%- if link_type == 'video' -%}
        <svg class="h-5 w-5 fill-base-content stroke-base-content/40" viewBox="0 0 24 24" fill="none" stroke-width="1.5" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <path d="M10 8l6 4-6 4V8z" fill="currentColor" stroke="none" />
        </svg>
      {%- else -%}
        <svg class="h-5 w-5 fill-base-content stroke-base-content/40" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
      {%- endif -%}
    </div>
    <div>
      <div>
        <span class="font-semibold text-base-content">{{ title }}</span>
        {%- if duration_label != blank -%}
          <span class="mx-2 hidden text-base-content/30 sm:inline">·</span>
          <span class="hidden text-base-content/60 sm:inline">{{ duration_label }}</span>
        {%- endif -%}
      </div>
      {%- if description != blank -%}
        <p class="text-base-content/70">{{ description }}</p>
      {%- endif -%}
      {%- if duration_label != blank -%}
        <div class="text-base-content/60 sm:hidden">{{ duration_label }}</div>
      {%- endif -%}
    </div>
  </a>
</div>
