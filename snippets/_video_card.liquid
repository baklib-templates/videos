<a href="{{ href }}" data-turbo-frame="main-content-frame" data-turbo-action="advance" class="group block">
  <div class="relative">
    <img
      src="{{ thumbnail }}"
      alt=""
      width="400"
      height="225"
      class="aspect-video w-full rounded-lg bg-base-200 object-cover"
      loading="lazy"
    />
    {%- if duration_label != blank -%}
      <div class="absolute bottom-3 right-3 rounded-sm bg-neutral/50 p-1 text-xs font-semibold text-neutral-content">
        {{ duration_label }}
      </div>
    {%- endif -%}
  </div>
  <p class="mt-4 text-sm/6 font-semibold text-base-content">{{ title }}</p>
  {%- if subtitle != blank -%}
    <p class="text-sm/6 text-base-content/70">{{ subtitle }}</p>
  {%- endif -%}
</a>
