{%- assign root = site.pages['/'] -%}
{%- if root == blank -%}
  <p class="text-sm text-base-content/60">{{ 'theme.sidebar.empty' | t: 'No pages.' }}</p>
{%- else -%}
  <div class="space-y-8">
    {%- for mod in root.children_in_list -%}
      {%- if mod.template_name == 'channel' -%}
        <div>
          <h2 class="text-base/7 font-semibold text-pretty text-base-content sm:text-sm/6">
            <a
              href="{{ mod.path }}"
              class="hover:underline focus:underline outline-none"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
            >
              {{ mod.link_text | default: mod.name }}
            </a>
      
          </h2>
          {%- assign lessons = mod.children_in_list -%}
          {%- assign lessons_count = lessons | size -%}
          <div x-data="{ visibleCount: 5, step: 5, total: {{ lessons_count }} }">
            <ul class="mt-4 flex flex-col gap-4 border-l border-base-300/30 text-base/7 text-base-content/70 sm:mt-3 sm:gap-3 sm:text-sm/6">
              {%- for lesson in lessons -%}
                <li
                  class="-ml-px flex border-l border-transparent pl-4 hover:border-base-300 hover:text-base-content has-[a[aria-current=page]]:border-base-content"
                  x-show="{{ forloop.index }} <= visibleCount"
                  x-cloak
                >
                  <a
                    href="{{ lesson.path }}"
                    data-turbo-frame="main-content-frame"
                    data-turbo-action="advance"
                    class="aria-[current=page]:font-medium aria-[current=page]:text-base-content"
                    {% if current_page and lesson.id == current_page.id %}aria-current="page"{% endif %}
                  >
                    {{ lesson.link_text | default: lesson.name }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
            {%- if lessons_count > 5 -%}
              <button
                type="button"
                class="mt-3 rounded-md px-3 py-1.5 text-xs font-medium text-base-content/70 hover:bg-base-content/5 hover:text-base-content"
                x-show="visibleCount < total"
                @click="visibleCount = Math.min(total, visibleCount + step)"
              >
                {{ 'theme.sidebar.load_more' | t: 'Load more' }}
              </button>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
{%- endif -%}
