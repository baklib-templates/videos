{
  "settings_schema": {
    "site_settings": {
      "name": "Site settings",
      "settings": {
        "brand_name": {
          "label": "Brand name"
        },
        "brand_slogan": {
          "label": "Course summary (homepage)"
        },
        "hero_image_url": {
          "label": "Homepage hero background"
        }
      }
    },
    "custom_html": {
      "name": "Custom HTML",
      "settings": {
        "head_html": {
          "label": "Head HTML",
