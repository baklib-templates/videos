        },
        "header_menu_html": {
          "label": "Header menu HTML",
          "info": "Rendered in the desktop top navigation. Add navigation links here.",
          "placeholder": "<a href=\"/\">Home</a>"
        },
        "footer_menu_html": {
          "label": "Footer menu HTML",
          "info": "Rendered in the footer area. Add navigation links here.",
          "placeholder": "<a href=\"/terms\">Terms</a>"
        }
      }
    }
  },
  "templates": {
    "index": {
      "name": "Course index",
      "description": "Course overview with modules"
    },
    "channel": {
      "name": "Course module",
      "description": "Lesson list for one module",
      "settings": {
        "description": {
          "label": "Description"
        }
      }
    },
    "channel.grid": {
      "name": "Grid channel",
      "description": "Video card grid (e.g. interviews)",
      "settings": {
        "description": {
          "label": "Description"
        }
      }
