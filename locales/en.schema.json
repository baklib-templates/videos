    "page": {
      "name": "Lesson / detail page",
      "description": "Video + prose + optional protected section",
      "settings": {
        "title": {
          "label": "Title (e.g. Interview)"
        },
        "description": {
          "label": "Short description"
        },
        "video_asset_url": {
          "label": "Video asset",
          "info": "Select a video from the asset library. If not set, External video URL below will be used."
        },
        "external_video_url": {
          "label": "External video URL (fallback)"
        },
        "thumb_image_url": {
          "label": "Poster image",
          "info": "Used as the video poster and list thumbnail."
        },
        "content": {
          "label": "Body"
        },
        "protected_content": {
          "label": "Protected content"
        }
      }
    }
